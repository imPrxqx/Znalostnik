{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Match Up Activity Answer",
  "type": "object",
  "additionalProperties": false,

  "required": [ "selected" ],

  "properties": {
    "selected": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,

        "required": [ "leftId", "rightId" ],

        "properties": {
          "leftId": {
            "type": "string",
            "format": "uuid"
          },

          "rightId": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  }
}