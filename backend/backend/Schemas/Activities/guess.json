{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Guess Activity Content",
  "type": "object",
  "additionalProperties": false,

  "required": [ "text", "style" ],

  "properties": {
    "text": {
      "type": "string",
      "minLength": 1
    },

    "style": {
      "type": "object",
      "additionalProperties": false,

      "properties": {
        "fontFamily": {
          "type": "string"
        },
        "fontSize": {
          "type": "number",
          "minimum": 1
        },
        "color": {
          "type": "string"
        },
        "bold": {
          "type": "boolean"
        },
        "italic": {
          "type": "boolean"
        },
        "underline": {
          "type": "boolean"
        }
      }
    }
  }
}